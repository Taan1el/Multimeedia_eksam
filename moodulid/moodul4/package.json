{
  "name": "slow-pour-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node app.js",
    "dev": "npm run build && nodemon app.js",
    "build": "vite build",
    "migrate": "node src/db/migrate.js",
    "test": "npm run test:integration",
    "test:integration": "node --test --test-concurrency=1 tests/integration/app.test.js",
    "test:browser": "playwright test",
    "test:server": "node scripts/start-test-server.mjs",
    "check": "npm run build && npm run test:integration && npm run test:browser && npm audit --audit-level=high"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "compression": "^1.8.1",
    "csrf-sync": "^4.2.1",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "gsap": "^3.15.0",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.10",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.0.0",
    "html-validate": "^11.5.2",
    "nodemon": "^3.1.10",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0"
  }
}
